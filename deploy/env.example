# 复制为 /etc/student-system.env 或项目目录下的 .env，由 systemd EnvironmentFile 加载
# 公网仅 IP 访问时，把下面 IP 换成你的服务器公网 IP（或内网访问则写内网 IP）

DJANGO_SECRET_KEY=请替换为长随机字符串
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=203.0.113.10,127.0.0.1
# 跨域：前端与 API 不同源时填写完整 Origin，逗号分隔（同域部署可留空）
# 示例：http://203.0.113.10,http://127.0.0.1:5173
DJANGO_CORS_ALLOWED_ORIGINS=http://203.0.113.10
# 仅在必须携带 Cookie 等凭证且已配置上方白名单时设为 1（默认不配）
# DJANGO_CORS_ALLOW_CREDENTIALS=1

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=student_app
MYSQL_PASSWORD=请设置强密码
MYSQL_DATABASE=student_system
